          }
        },
        {
          "name": "TC-ITEMS-02 · GET /api/items/{id} — BUG-008 (int vs Guid)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// TC-ITEMS-02: BUG-008 — GetItemById(int id) but Entity.Id is Guid",
                  "// /api/items/1 (int) → FindAsync(1) on Guid PK → 500 InvalidCastException",
                  "// /api/items/<guid> → model binding Guid→int → 400 Bad Request",
                  "// Fix: change GetItemById(int id) → GetItemById(Guid id)",
                  "",
                  "const code = pm.response.code;",
                  "console.log('[TC-ITEMS-02] Status: ' + code);",
                  "console.log('[TC-ITEMS-02] URL: ' + pm.request.url.toString());",
                  "",
                  "// Document BUG-008: both 400 and 500 are wrong — 200 or 404 expected",
                  "pm.test('TC-ITEMS-02 · BUG-008: 500 returned (int→Guid crash) — expected 200 or 404', () => {",
                  "  if (code === 500) {",
                  "    console.error('[BUG-008] 500: FindAsync(int) on Guid PK throws InvalidCastException');",
                  "    console.error('[BUG-008] Fix: GetItemById(int id) → GetItemById(Guid id)');",
                  "  } else if (code === 400) {",
                  "    console.error('[BUG-008] 400: model binding failed — Guid value cannot bind to int param');",
                  "    console.error('[BUG-008] Fix: GetItemById(int id) → GetItemById(Guid id)');",
                  "  }",
                  "  // Test FAILS intentionally to surface BUG-008",
                  "  pm.expect([200, 404]).to.include(code,",
                  "    'BUG-008: GetItemById(int id) wrong type — got ' + code + ', expected 200 or 404. Fix: change param to Guid');",
                  "});",
                  "",
                  "// SBR checks regardless",
                  "pm.test('TC-ITEMS-02 · SBR-01: No HTML in response', () => {",
                  "  pm.expect(pm.response.text()).to.not.include('<html>');",
                  "});",
                  "pm.test('TC-ITEMS-02 · SBR-02: No stack trace', () => {",
                  "  pm.expect(pm.response.text()).to.not.include('StackTrace');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/items/1",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
