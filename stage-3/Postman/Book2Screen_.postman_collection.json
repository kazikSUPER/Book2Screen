      "name": "01 · Health",
      "description": "GET /api/health\nBUG-007: повертає plain text 'Healthy', не JSON.\nFix: додати ResponseWriter у MapHealthChecks() або UIResponseWriter.",
      "item": [
        {
          "name": "TC-HEALTH-01 · GET /api/health — plain text (BUG-007)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "// TC-HEALTH-01: Health Check",
                  "// BUG-007: /api/health returns plain text 'Healthy', NOT JSON",
                  "// Root cause: MapHealthChecks() called without ResponseWriter",
                  "// Fix: app.MapHealthChecks('/api/health', new HealthCheckOptions {",
                  "//   ResponseWriter = UIResponseWriter.WriteHealthCheckUIResponse });",
                  "",
                  "pm.test('TC-HEALTH-01 · Status 200', () => pm.response.to.have.status(200));",
                  "",
                  "// BUG-007: response is plain text, not JSON",
                  "// Check what we actually get",
                  "const raw = pm.response.text();",
                  "const isJSON = raw.trim().startsWith('{') || raw.trim().startsWith('[');",
                  "",
                  "pm.test('TC-HEALTH-01 · BUG-007: response is plain text (not JSON)', () => {",
                  "  // This documents the CURRENT buggy behavior",
                  "  pm.expect(isJSON).to.equal(false,",
                  "    'If this fails: BUG-007 is fixed! Health endpoint now returns JSON.');",
                  "  console.warn('[BUG-007] /api/health returns plain text: \"' + raw + '\"');",
                  "  console.warn('[BUG-007] Expected JSON: {\"status\":\"Healthy\", ...}');",
                  "  console.warn('[BUG-007] Fix: add ResponseWriter to MapHealthChecks()');",
                  "});",
                  "",
                  "// The actual content check (plain text)",
                  "pm.test('TC-HEALTH-01 · Response contains health status word', () => {",
                  "  pm.expect(raw.toLowerCase()).to.satisfy(t =>",
                  "    t.includes('healthy') || t.includes('degraded') || t.includes('unhealthy'),",
                  "    'Response should contain a health status word');",
                  "});",
                  "",
                  "console.log('[TC-HEALTH-01] Raw response: \"' + raw + '\"');",
                  "console.log('[TC-HEALTH-01] Content-Type: ' + pm.response.headers.get('Content-Type'));",
                  "console.log('[TC-HEALTH-01] Elapsed: ' + pm.response.responseTime + 'ms');"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/health",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "health"
              ]
            },
            "description": "TC-HEALTH-01: Health Check\nExpected (correct): HTTP 200, JSON: {status:'Healthy'}\nActual (BUG-007): HTTP 200, plain text 'Healthy'\n\nBUG-007 (NEW, Major, P2):\nRoot cause: MapHealthChecks() without ResponseWriter defaults to plain text.\nFix: add UIResponseWriter.WriteHealthCheckUIResponse to HealthCheckOptions."
          }
        },
